# Plantilla de variables de entorno. Copia este archivo como .env.local
# y completa los valores reales. El archivo .env.local NO se sube a git.

# Conexión a SQL Server
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=sistema_hoteles
DB_USER=tu_usuario_sql
DB_PASSWORD=tu_contraseña
DB_ENCRYPT=false

# Auth.js: clave para firmar el JWT de sesión.
# Genérala con: npx auth secret    (o: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET=
